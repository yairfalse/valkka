{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/templates/tauri/src-tauri/tauri.conf.json",
  "productName": "Valkka",
  "version": "0.1.0",
  "identifier": "com.falsesystems.valkka",
  "build": {
    "beforeBuildCommand": "",
    "frontendDist": "../priv/static"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null,
      "dangerousRemoteDomainIpcAccess": [
        {
          "domain": "localhost",
          "enableTauriAPI": false,
          "windows": ["main"],
          "plugins": []
        }
      ]
    },
    "trayIcon": {
      "tooltip": "Valkka — Agent Command Center",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/valkka-beam"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "depends": ["webkit2gtk-4.1"]
    }
  }
}
