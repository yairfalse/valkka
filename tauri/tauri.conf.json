{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Valkka",
  "version": "0.1.0",
  "identifier": "com.falsesystems.valkka",
  "build": {
    "beforeBuildCommand": "",
    "frontendDist": "../priv/static"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:4420; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "tooltip": "Valkka — Agent Command Center",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/valkka-beam"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "depends": ["webkit2gtk-4.1"]
    }
  }
}
